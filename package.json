{
  "name": "flow-ledger",
  "private": true,
  "scripts": {
    "prepare": "husky",

    "format": "pnpx @biomejs/biome format --write",
    "lint": "pnpx @biomejs/biome lint --write",
    "organize": "pnpx @biomejs/biome check --write",

    "apps:design-studio:dev": "pnpm --filter @flow-ledger/design-studio dev",
    "apps:design-studio:build": "pnpm --filter @flow-ledger/design-studio build",

    "apps:core-api:build": "pnpm --filter flow-ledger-core build",
    "apps:core-api:pre-build": "pnpm --filter flow-ledger-core prebuild",
    "apps:core-api:lint": "pnpm --filter flow-ledger-core lint",
    "apps:core-api:format": "pnpm --filter flow-ledger-core format",
    "apps:core-api:organize": "pnpm --filter flow-ledger-core organize",
    "apps:core-api:start": "pnpm --filter flow-ledger-core start",
    "apps:core-api:start:dev": "pnpm --filter flow-ledger-core start:dev",
    "apps:core-api:start:debug": "pnpm --filter flow-ledger-core start:debug",
    "apps:core-api:start:prod": "pnpm --filter flow-ledger-core start:prod",
    "apps:core-api:test": "pnpm --filter flow-ledger-core test",
    "apps:core-api:test:watch": "pnpm --filter flow-ledger-core test:watch",
    "apps:core-api:test:cov": "pnpm --filter flow-ledger-core test:cov",
    "apps:core-api:docker:db:up": "pnpm --filter flow-ledger-core docker:core-db:up",
    "apps:core-api:docker:db:down": "pnpm --filter flow-ledger-core docker:core-db:down",
    "apps:core-api:db:migration:generate": "pnpm --filter flow-ledger-core db:migration:generate",
    "apps:core-api:db:migration:apply": "pnpm --filter flow-ledger-core db:migration:apply",
    "apps:core-api:db:schema:generate": "pnpm --filter flow-ledger-core db:schema:generate",
    "apps:core-api:db:seed": "pnpm --filter flow-ledger-core db:seed",
    "apps:core-api:db:reset": "pnpm --filter flow-ledger-core db:reset"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "husky": "9.1.7"
  }
}
